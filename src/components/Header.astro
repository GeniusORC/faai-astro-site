---
import { NAV, SITE } from '../site';
---

<header class="site-header">
  <div class="wrap bar">
    <a class="brand" href="/">
      <span class="logo">
        <b>FAAI</b>
        <span class="logo-shine"></span>
      </span>
      <span class="name">{SITE.short}<small>福建省人工智能学会</small></span>
    </a>
    <details class="nav-toggle">
      <summary>菜单</summary>
      <nav class="nav">
        {NAV.map((item) => <a href={item.href}>{item.label}</a>)}
      </nav>
    </details>
  </div>
</header>
