---
import { NAV, SITE, SITE_CFG } from '../site';
---

{SITE_CFG.top_announce_text && (
  <div class="announce-bar">
    <div class="wrap">
      {SITE_CFG.top_announce_link
        ? <a href={SITE_CFG.top_announce_link}>{SITE_CFG.top_announce_text}</a>
        : <span>{SITE_CFG.top_announce_text}</span>}
    </div>
  </div>
)}

<header class="site-header">
  <div class="wrap bar">
    <a class="brand" href="/">
      <span class="logo">
        <b>FAAI</b>
        <span class="logo-shine"></span>
      </span>
      <span class="name">{SITE.short}<small>福建省人工智能学会</small></span>
    </a>
    <details class="nav-toggle">
      <summary>菜单</summary>
      <nav class="nav">
        {NAV.map((item) => <a href={item.href}>{item.label}</a>)}
      </nav>
    </details>
  </div>
</header>
