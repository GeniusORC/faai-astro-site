---
import { NAV, SITE, SITE_CFG } from '../site';
---

<footer class="site-footer">
  <div class="wrap">
    <div class="cols">
      <div>
        <h4>{SITE.title}</h4>
        <p>{SITE_CFG.footer_about}</p>
      </div>
      <div>
        <h4>快速入口</h4>
        {NAV.slice(1).map((item) => <a href={item.href}>{item.label}</a>)}
      </div>
      <div>
        <h4>联系我们</h4>
        <a href={`mailto:${SITE_CFG.contact_email}`}>{SITE_CFG.contact_email}</a>
        <a href="/gong-wei-jian-jie">关于我们</a>
      </div>
    </div>
    <div class="copy">
      © {new Date().getFullYear()} {SITE_CFG.footer_copyright || SITE.title}
    </div>
  </div>
</footer>
