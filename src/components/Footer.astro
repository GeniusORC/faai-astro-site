      <div>
        <h4>{SITE.title}</h4>
        <p>
          搭建福建省人工智能领域「企业—高校—科研」协同桥梁，提供需求对接、专家登记、入会申请、课题申报与活动交流一站式服务。
        </p>
      </div>
      <div>
        <h4>快速入口</h4>
        {NAV.slice(1).map((item) => <a href={item.href}>{item.label}</a>)}
      </div>
      <div>
        <h4>联系我们</h4>
        <a href="mailto:qigongwei@faai.org">qigongwei@faai.org</a>
        <a href="/gong-wei-jian-jie">关于我们</a>
