---
import BaseLayout from '../layouts/BaseLayout.astro';
import Gallery from '../components/Gallery.astro';
import ModuleCard from '../components/ModuleCard.astro';
import NoticeList from '../components/NoticeList.astro';
import { getCollection } from 'astro:content';
import home from '../data/home.json';

const notices = (await getCollection('notices'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 5)
  .map((n) => ({
    title: n.data.title,
    date: n.data.date,
    category: n.data.category,
    permalink: `/notices/${n.slug}`,
  }));
---

<BaseLayout>
  <section class="hero">
    <div class="wrap">
      {home.hero_tag && <span class="tag">{home.hero_tag}</span>}
      <h1>{home.hero_title}</h1>
      <div class="accent"></div>
      {home.hero_desc && <p>{home.hero_desc}</p>}
      <div class="actions">
        {home.hero_btns.map((b) => (
          <a class={b.style === 'ghost' ? 'btn-ghost' : 'btn-primary'} href={b.href}>{b.text}</a>
        ))}
      </div>
    </div>
  </section>

  <div class="wrap">
    <section class="section" id="gallery">
      <div class="sec-title">
        <span class="bar"></span>
        <h3>活动精选</h3>
        <span class="more"><a href="/notices">更多通知 ›</a></span>
      </div>
      <Gallery slides={home.slides} />
    </section>

    <section class="section alt" id="modules">
      <div class="sec-title">
        <span class="bar"></span>
        <h3>服务大厅</h3>
        <span class="more">五大核心服务</span>
      </div>
      <div class="svc-grid">
        {home.modules.map((m) => <ModuleCard {...m} />)}
      </div>
    </section>

    <section class="section" id="notice">
      <div class="sec-title">
        <span class="bar"></span>
        <h3>活动通知</h3>
        <span class="more"><a href="/notices">更多 ›</a></span>
      </div>
      <NoticeList items={notices} />
    </section>
  </div>
</BaseLayout>
