---
import BaseLayout from '../../layouts/BaseLayout.astro';
import NoticeList from '../../components/NoticeList.astro';
import { getCollection } from 'astro:content';

const items = (await getCollection('notices'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .map((n) => ({
    title: n.data.title,
    date: n.data.date,
    category: n.data.category,
    permalink: `/notices/${n.slug}`,
  }));
---

<BaseLayout title="活动通知 | 福建省人工智能学会企业工作委员会">
  <div class="wrap">
    <div class="crumbs"><a href="/">首页</a> › 活动通知</div>
    <article class="page">
      <h1>活动通知</h1>
      <p class="lead">最新通知公告、活动预告与行业资讯。</p>
      <NoticeList items={items} />
    </article>
  </div>
</BaseLayout>
