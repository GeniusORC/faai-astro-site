---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const demands = (await getCollection('demands'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="企业需求库 | 福建省人工智能学会企业工作委员会">
  <div class="wrap">
    <div class="crumbs"><a href="/">首页</a> › 企业需求库</div>
    <article class="page">
      <h1>企业需求库</h1>
      <p class="lead">
        面向福建省内企业公开征集人工智能相关需求，统一入库后由企工委组织学会专家进行匹配与对接，推动联合攻关与成果转化。
      </p>

      <h2>需求类型</h2>
      <p>
        · 技术攻关需求（算法、模型、系统）<br />
        · 人才与团队需求<br />
        · 场景与数据合作需求
      </p>

      <h2>最新需求</h2>
      {demands.length === 0 ? (
        <p>暂无已发布需求，敬请期待。</p>
      ) : (
        <div class="demand-list">
          {demands.map((d) => (
            <a class="demand-item" href={`/demands/${d.slug}`}>
              <div class="demand-meta">
                <span class="demand-category">{d.data.category}</span>
                <span class="demand-date">{d.data.date.toLocaleDateString('zh-CN')}</span>
              </div>
              <h3>{d.data.title}</h3>
              <p class="demand-company">{d.data.company}</p>
              <p class="demand-excerpt">{d.data.excerpt}</p>
            </a>
          ))}
        </div>
      )}

      <h2>提交需求</h2>
      <p>
        需求提交表单正在接入中。现阶段可通过「活动通知」栏目关注线下需求对接会，或将需求发送至
        <a href="mailto:qigongwei@faai.org">qigongwei@faai.org</a>。
      </p>

      <div class="note">
        说明：企业需求库的"结构化检索 / 在线提交"为下一阶段功能。本站为静态架构，检索可由前端（Pagefind / Fuse.js）实现，提交需接入表单后端（见各申请页）。
      </div>
    </article>
  </div>
</BaseLayout>
